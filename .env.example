# =========================================================
# Ticketing System Environment Example
# ---------------------------------------------------------
# 사용 방법
# 1. 로컬 실행: cp .env.example .env 후 로컬 값으로 수정
# 2. EC2 배포: cp .env.example .env 후 TODO(EC2) 항목을 실제 값으로 수정
# 3. 실제 .env 파일은 절대 Git에 커밋하지 않음
# =========================================================

# =========================================================
# Application DB connection
# ---------------------------------------------------------
# 용도: 각 Spring Boot 서비스 datasource 접속값
#
# LOCAL Docker Compose:
#   DB_HOST=postgres
#   DB_PORT=5432
#   DB_NAME=ticketing
#   DB_USERNAME=ticketing
#   DB_PASSWORD=change-me-local
#
# EC2 Deploy:
#   TODO(EC2): DB_HOST=<RDS_ENDPOINT>
#   TODO(EC2): DB_PORT=5432
#   TODO(EC2): DB_NAME=ticketing
#   TODO(EC2): DB_USERNAME=postgres 또는 RDS 생성 시 지정한 사용자명
#   TODO(EC2): DB_PASSWORD=<REAL_RDS_PASSWORD>
#
# 중요:
# - 애플리케이션 datasource는 DB_* 값만 사용
# - DB_SCHEMA는 전역 .env에 넣지 않는 것을 권장
#   각 서비스 yml의 기본값(user_service, club_service 등)을 사용
# - 기존 POSTGRES_* 값은 사용하지 않음
#   만약 docker-compose의 postgres 컨테이너가 POSTGRES_*를 참조하고 있다면
#   docker-compose에서 POSTGRES_DB=${DB_NAME}, POSTGRES_USER=${DB_USERNAME},
#   POSTGRES_PASSWORD=${DB_PASSWORD} 형태로 매핑 필요
# =========================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ticketing
DB_USERNAME=ticketing
DB_PASSWORD=change-me-local

# =========================================================
# JPA
# ---------------------------------------------------------
# LOCAL: update / true 가능
# EC2: update / false 권장
# =========================================================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# =========================================================
# Keycloak
# ---------------------------------------------------------
# TODO(EC2): KEYCLOAK_ADMIN_PASSWORD=<REAL_KEYCLOAK_ADMIN_PASSWORD>
# =========================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local
KEYCLOAK_DB=keycloak

KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_REALM=ticketing
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# =========================================================
# JWT / Resource Server
# ---------------------------------------------------------
# LOCAL Docker Compose:
#   JWT_ISSUER_URI=http://localhost:18080/realms/ticketing
#   JWT_JWK_SET_URI=http://keycloak:8080/realms/ticketing/protocol/openid-connect/certs
#
# EC2 Deploy:
#   TODO(EC2): JWT_ISSUER_URI=http://<EC2_PUBLIC_IP>:18080/realms/ticketing
#   JWT_JWK_SET_URI=http://keycloak:8080/realms/ticketing/protocol/openid-connect/certs
# =========================================================
JWT_ISSUER_URI=http://localhost:18080/realms/ticketing
JWT_JWK_SET_URI=http://keycloak:8080/realms/ticketing/protocol/openid-connect/certs

# 하위 호환용으로 필요한 경우만 사용
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:18080/realms/ticketing

# =========================================================
# Redis
# ---------------------------------------------------------
# LOCAL/EC2 Docker Compose 내부 서비스명 기준
# =========================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =========================================================
# Kafka
# ---------------------------------------------------------
# LOCAL/EC2 Docker Compose 내부 서비스명 기준
# compose advertised listener 설정에 맞춰 사용
# =========================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:19092

# =========================================================
# Config Server
# =========================================================
CONFIG_SERVER_HOST=config-server
CONFIG_SERVER_PORT=10002
CONFIG_SERVER_URL=http://config-server:10002
SPRING_CONFIG_IMPORT=optional:configserver:http://config-server:10002
SPRING_CLOUD_CONFIG_URI=http://config-server:10002

# Spring Cloud Config {cipher} 사용 시에만 필요
# TODO(EC2, optional): CONFIG_ENCRYPT_KEY=<RANDOM_ENCRYPT_KEY>
# CONFIG_ENCRYPT_KEY=change-me-encrypt-key

# =========================================================
# Eureka
# =========================================================
EUREKA_DEFAULT_ZONE=http://eureka-server:10001/eureka/
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:10001/eureka/

# =========================================================
# Zipkin
# =========================================================
ZIPKIN_URL=http://zipkin:9411/api/v2/spans
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://zipkin:9411/api/v2/spans

# =========================================================
# GitHub Packages
# ---------------------------------------------------------
# common-module 다운로드용
# TODO(EC2): GPR_USER=<YOUR_GITHUB_USERNAME>
# TODO(EC2): GPR_TOKEN=<REAL_GITHUB_PACKAGES_TOKEN>
# =========================================================
GPR_USER=your-github-username
GPR_TOKEN=your-github-token

# =========================================================
# Service Secrets
# ---------------------------------------------------------
# TODO(EC2): TOSS_SECRET_KEY=<REAL_OR_TEST_TOSS_SECRET_KEY>
# TODO(EC2): QUEUE_TOKEN_SECRET=<RANDOM_QUEUE_TOKEN_SECRET>
# =========================================================
TOSS_SECRET_KEY=change-me
QUEUE_TOKEN_SECRET=change-me-local-queue-token-secret

# =========================================================
# Host ports
# ---------------------------------------------------------
# 호스트 PC/EC2에서 컨테이너로 노출할 포트
# =========================================================
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
KAFKA_HOST_PORT=19092
KEYCLOAK_HOST_PORT=18080
ZIPKIN_HOST_PORT=9411
CONFIG_SERVER_HOST_PORT=10002
EUREKA_HOST_PORT=10001
GATEWAY_PORT=10000
USER_SERVICE_PORT=20001
MATCH_SERVICE_PORT=20002
CLUB_PORT=20003
SEAT_SERVICE_PORT=20004
RESERVATION_SERVICE_PORT=20005
PAYMENT_SERVICE_PORT=20006
QUEUE_SERVICE_PORT=20007
